{
  "name": "convoguard",
  "private": true,
  "version": "1.0.0",
  "description": "ConvoGuard — Real-time AI manipulation detection and analytics platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @convoguard/database db:generate",
    "db:migrate": "pnpm --filter @convoguard/database db:migrate",
    "db:seed": "pnpm --filter @convoguard/database db:seed",
    "db:studio": "pnpm --filter @convoguard/database db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
