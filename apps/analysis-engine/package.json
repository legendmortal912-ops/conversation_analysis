{
  "name": "@convoguard/analysis-engine",
  "version": "1.0.0",
  "private": true,
  "description": "ConvoGuard Analysis Engine — Real-time AI manipulation detection",
  "scripts": {
    "dev": "uv run uvicorn src.main:app --host 0.0.0.0 --port 8001 --reload",
    "build": "echo 'Python service — no build step required'",
    "start": "uv run uvicorn src.main:app --host 0.0.0.0 --port 8001",
    "test": "uv run pytest tests/ -v",
    "lint": "uv run ruff check src/",
    "clean": "rm -rf __pycache__ .pytest_cache .mypy_cache .ruff_cache dist",
    "train:generate-data": "uv run python -m src.training.generate_training_data",
    "train:classifier": "uv run python -m src.training.train_classifier",
    "typecheck": "uv run mypy src/"
  }
}
