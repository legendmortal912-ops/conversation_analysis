{
  "name": "@convoguard/database",
  "version": "1.0.0",
  "private": true,
  "description": "Database client wrappers (Postgres, ImmuDB, Redis) and Prisma schema for ConvoGuard",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "seed:b2b": "tsx scripts/seed-b2b.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "bullmq": "^5.30.0",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/node": "^25.9.3",
    "bcryptjs": "^2.4.3",
    "prisma": "^6.2.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
