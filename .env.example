# ═══════════════════════════════════════════════════════════
# ConvoGuard — Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════

NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql://convoguard:convoguard_dev@localhost:5432/convoguard
TIMESCALE_URL=postgresql://convoguard:convoguard_dev@localhost:5433/convoguard_metrics

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── immudb ───────────────────────────────────────────────
IMMUDB_HOST=localhost
IMMUDB_PORT=3322
IMMUDB_USER=immudb
IMMUDB_PASSWORD=immudb
IMMUGW_URL=http://localhost:3323

# ─── MinIO (S3-compatible) ────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=convoguard
MINIO_SECRET_KEY=convoguard_dev_secret
MINIO_BUCKET=convoguard-reports
MINIO_USE_SSL=false

# ─── JWT Auth ─────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Ed25519 Signing (for Merkle checkpoints) ────────────
# Generate with: node -e "const{generateKeyPair}=require('@convoguard/hash-chain');console.log(generateKeyPair())"
SIGNING_PRIVATE_KEY=
SIGNING_PUBLIC_KEY=

# ─── Stripe Billing ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_FREE_PRICE_ID=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=

# ─── SMTP Email ──────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@convoguard.dev

# ─── Service URLs (internal) ─────────────────────────────
API_GATEWAY_URL=http://localhost:3000
INGEST_SERVICE_URL=http://localhost:3001
AUTH_SERVICE_URL=http://localhost:3002
BILLING_SERVICE_URL=http://localhost:3003
ALERT_SERVICE_URL=http://localhost:3004
DASHBOARD_BACKEND_URL=http://localhost:3005
ANALYSIS_ENGINE_URL=http://localhost:8001

# ─── Frontend ────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000

# ─── Elasticsearch (future) ──────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=debug
